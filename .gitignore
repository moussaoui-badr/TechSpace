# ============================================================
# .gitignore — TechSpace (Frontend React + Backend ASP.NET)
# ============================================================

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini
*.swp

# ---------- IDE / Editeurs ----------
.vs/
.vscode/
*.user
*.suo
*.userprefs
*.sln.DotSettings.user
.idea/
*.iml

# ---------- Node / Frontend ----------
node_modules/
dist/
dist-ssr/
build/
.vite/
.turbo/
*.local
.env
.env.local
.env.*.local
.eslintcache
.pnpm-store/
coverage/
.nyc_output/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------- .NET / Backend ----------
bin/
obj/
out/
*.dll
*.exe
*.pdb
*.mdb
*.nupkg
*.snupkg
*.vsidx
*.ide

# ASP.NET
**/wwwroot/uploads/*
!**/wwwroot/uploads/.gitkeep
*.cache
*.log

# Configuration sensible
appsettings.Development.json
appsettings.Production.json
appsettings.Local.json
secrets.json

# Publish
publish/
PublishProfiles/

# EF Core (garder les migrations, ignorer les artefacts de design)
*.scaffold.cs

# ---------- Base de donnees locale ----------
*.mdf
*.ldf
*.ndf
*.bacpac
*.dacpac

# ---------- Divers ----------
*.tmp
*.bak
*.old
.history/
